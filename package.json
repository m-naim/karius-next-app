  "private": true,
  "scripts": {
    "start": "next dev --turbo",
    "dev": "cross-env next dev --turbo",
    "build": "cross-env INIT_CWD=$PWD next build --turbo",
    "postbuild": "cross-env NODE_OPTIONS='--experimental-json-modules' node ./scripts/postbuild.mjs",
